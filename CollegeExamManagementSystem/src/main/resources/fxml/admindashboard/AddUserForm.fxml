<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" 
      fx:controller="admin.AddUserFormController"
      spacing="10" padding="20">
    
    <Label text="Add New User" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    
    <GridPane hgap="10" vgap="10">
        <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        
        <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="idField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        
        <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        
        <Label text="Role:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <ComboBox fx:id="roleComboBox" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
    </GridPane>
    
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel"/>
        <Button text="Add User" onAction="#handleAddUser" styleClass="action-btn"/>
    </HBox>
</VBox>